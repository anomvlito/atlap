# ============================================================
# ATLAP — Variables de entorno (.env.example)
# Copiar este archivo a .env y completar los valores.
# NUNCA commitear el .env real.
# ============================================================


# ------------------------------------------------------------
# BASE DE DATOS — Neon PostgreSQL
# Obtener desde: console.neon.tech → tu proyecto → Connection Details
# Elegir "Pooled connection" y copiar la connection string completa.
# Incluir "?sslmode=require" al final.
# ------------------------------------------------------------
VITE_DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/atlap?sslmode=require

# Variables individuales (para scripts de migración con drizzle-kit)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/atlap?sslmode=require
PGHOST=ep-xxx.region.aws.neon.tech
PGDATABASE=atlap
PGUSER=atlap_owner
PGPASSWORD=
PGPORT=5432


# ------------------------------------------------------------
# AUTENTICACIÓN — Clerk
# Obtener desde: dashboard.clerk.com → tu app → "API Keys"
# ------------------------------------------------------------

# Publishable key (segura en el cliente, empieza con "pk_test_" o "pk_live_")
VITE_CLERK_PUBLISHABLE_KEY=pk_test_

# Secret key (SOLO server-side, nunca con prefijo VITE_)
# Necesaria cuando se agreguen API routes / Vercel Functions
CLERK_SECRET_KEY=sk_test_


# ------------------------------------------------------------
# ENTORNO
# ------------------------------------------------------------
VITE_APP_ENV=development
